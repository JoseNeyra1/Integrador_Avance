# Copia este archivo a .env y ajusta los valores para tu entorno.
# docker-compose.yml y application.yaml leen estas mismas variables.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=TiendaFlic_db
DB_USERNAME=root
DB_PASSWORD=admin123
# Maximo de conexiones simultaneas a la base de datos. Bajalo si tu proveedor de MySQL
# tiene un limite de conexiones por usuario (ej. planes gratuitos como Clever Cloud DEV).
DB_POOL_SIZE=3

# Genera un secreto propio y largo (32+ caracteres) para producción.
JWT_SECRET=cambia-este-secreto-en-produccion-por-uno-de-al-menos-32-caracteres
JWT_EXPIRATION_MS=28800000

# Orígenes del frontend permitidos por CORS, separados por coma.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Credenciales root para el contenedor de MySQL en docker-compose.
MYSQL_ROOT_PASSWORD=admin123
